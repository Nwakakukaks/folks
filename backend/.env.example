# Folks Backend Configuration

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# Scope API URL - Your Daydream Scope server
SCOPE_API_URL=http://localhost:8000

# Groq AI API Key (get free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# Environment mode: local or prod
# local = uses longlive pipeline only
# prod = uses full multi-pipeline set (glitch-realm, crystal-box, etc.)
SCOPE_ENV=prod

# Agent reasoning model (default: qwen/qwen3-32b)
# AGENT_REASON_MODEL=qwen/qwen3-32b

# Effect video count for select_effect action (default: 5)
# EFFECT_VIDEO_COUNT=5

# GitHub Integration (for publishing)
# GITHUB_TOKEN=your_github_token_here
# GITHUB_OWNER=your_github_username

# Debug mode (default: false)
# DEBUG=false

# ===========================================
# SCOPE CLOUD (for remote inference)
# ===========================================

# Get these from your Scope/Cloud account
# SCOPE_CLOUD_APP_ID=your_cloud_app_id
# SCOPE_CLOUD_API_KEY=your_cloud_api_key
# SCOPE_CLOUD_USER_ID=your_user_id
