# Folks Frontend Configuration

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# Groq AI API Key (get free key at https://console.groq.com)
NEXT_PUBLIC_GROQ_API_KEY=your_groq_api_key_here

# Backend API URL
# For local development: http://localhost:3001
# For production: your deployed backend URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# ===========================================
# SCOPE CONFIGURATION
# ===========================================

# Environment mode: local or prod
# local = uses longlive pipeline only
# prod = uses full multi-pipeline set
NEXT_PUBLIC_SCOPE_ENV=prod

# Scope API URL (optional - for direct Scope communication)
# NEXT_PUBLIC_SCOPE_API_URL=http://localhost:8000

# Effect video count (must match backend)
# NEXT_PUBLIC_EFFECT_VIDEO_COUNT=5

# ===========================================
# SCOPE CLOUD (for remote inference)
# ===========================================

# Get these from your Scope/Cloud account
# NEXT_PUBLIC_SCOPE_CLOUD_APP_ID=your_cloud_app_id
# NEXT_PUBLIC_SCOPE_CLOUD_USER_ID=your_user_id

# ===========================================
# AGENT TIMING (milliseconds)
# ===========================================

# How often the agent reasons (default: 10000 = 10 seconds)
# NEXT_PUBLIC_AGENT_REASONING_INTERVAL_MS=10000

# How often parameters can be sent (default: 10000 = 10 seconds)
# NEXT_PUBLIC_AGENT_CONTROL_INTERVAL_MS=10000

# How often prompts are updated (default: 30000 = 30 seconds)
# NEXT_PUBLIC_AGENT_PROMPT_INTERVAL_MS=30000

# ===========================================
# AUDIO CONFIGURATION
# ===========================================

# Audio metrics provider: webaudio, osc, maxmsp, or hybrid
# NEXT_PUBLIC_AUDIO_METRICS_PROVIDER=webaudio

# OSC Bridge WebSocket URL (if using OSC provider)
# NEXT_PUBLIC_OSC_BRIDGE_WS_URL=ws://localhost:8080

# ===========================================
# SUPABASE (optional - for future features)
# ===========================================

# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
